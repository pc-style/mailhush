---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Why MailHush Exists</title>
  <meta property="og:title" content="Why MailHush Exists" />
  <meta property="og:description" content="Anthropic leaves your email hanging out in plain sight. so we fixed their clown show." />
  <meta property="og:image" content="./assets/social-card-aggressive.png" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/png" href="./assets/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #05050a;
      --surface: #0a0b14;
      --surface-raised: #10111c;
      --border: rgba(139, 92, 246, 0.1);
      --border-accent: rgba(139, 92, 246, 0.25);
      --purple: #a855f7;
      --purple-dim: #7c3aed;
      --blue: #6366f1;
      --accent: #a855f7;
      --green: #22c55e;
      --green-dim: #16a34a;
      --red: #ef4444;
      --red-glow: rgba(239, 68, 68, 0.12);
      --text: #d0d5e3;
      --text-dim: #4a5068;
      --text-muted: #2a2d3e;
      --font-display: 'Instrument Serif', Georgia, serif;
      --font-mono: 'JetBrains Mono', 'SF Mono', monospace;
      --font-body: 'Outfit', system-ui, sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
      scrollbar-width: thin;
      scrollbar-color: var(--text-muted) transparent;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      line-height: 1.6;
      overflow-x: hidden;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
    }

    /* Ambient Glow Effects */
    .glow-top, .glow-bottom {
      position: absolute;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(168, 85, 247, 0.08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: -1;
    }
    .glow-top { top: -300px; left: 50%; transform: translateX(-50%); }
    .glow-bottom { bottom: -300px; left: 50%; transform: translateX(-50%); background: radial-gradient(circle, rgba(99, 102, 241, 0.05) 0%, transparent 70%); }

    .page {
      width: 100%;
      max-width: 640px;
      padding: 80px 24px;
      position: relative;
      z-index: 1;
    }

    /* Typography */
    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(40px, 8vw, 64px);
      line-height: 0.95;
      letter-spacing: -0.02em;
      margin-bottom: 24px;
      color: #f1f5f9;
      animation: fadeSlideIn 0.8s ease both;
    }
    .hero-headline em {
      color: var(--text-muted);
      font-style: italic;
    }
    .hero-headline .accent {
      background: linear-gradient(135deg, var(--purple), var(--blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      padding-right: 4px; /* Fix clipping bug on some browsers */
    }

    .hero-sub {
      font-size: 18px;
      color: var(--text-dim);
      margin-bottom: 48px;
      max-width: 90%;
      animation: fadeSlideIn 0.8s 0.1s ease both;
    }
    .hero-sub strong {
      color: var(--text);
      font-weight: 500;
    }

    /* Terminal Mockup */
    .terminal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 64px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
      animation: fadeSlideIn 0.8s 0.2s ease both;
    }
    .terminal-bar {
      background: var(--surface-raised);
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid var(--border);
    }
    .terminal-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--text-muted);
    }
    .terminal-dot:nth-child(1) { background: #ef4444; opacity: 0.8; }
    .terminal-dot:nth-child(2) { background: #eab308; opacity: 0.8; }
    .terminal-dot:nth-child(3) { background: #22c55e; opacity: 0.8; }
    .terminal-bar span {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-dim);
    }
    .terminal-body {
      padding: 24px;
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.7;
    }
    .comment { color: var(--text-dim); }
    .prompt { color: var(--purple); margin-right: 8px; }
    .dim { color: var(--text-dim); }
    .leak { color: var(--red); background: var(--red-glow); padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(239, 68, 68, 0.2); }
    .safe { color: var(--green); background: rgba(34, 197, 94, 0.1); padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(34, 197, 94, 0.2); }
    .cursor-blink {
      display: inline-block;
      width: 8px;
      height: 15px;
      background: var(--purple);
      vertical-align: middle;
      animation: blink 1s step-end infinite;
    }

    /* Scenarios */
    .section-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--purple);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      animation: fadeSlideIn 0.8s 0.3s ease both;
    }
    .section-label::after {
      content: '';
      height: 1px;
      flex-grow: 1;
      background: var(--border);
    }

    .scenarios {
      display: flex;
      flex-direction: column;
      gap: 32px;
      margin-bottom: 64px;
      animation: fadeSlideIn 0.8s 0.4s ease both;
    }
    .scenario {
      display: flex;
      gap: 20px;
    }
    .scenario-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .scenario-text h3 {
      font-family: var(--font-body);
      font-size: 18px;
      font-weight: 600;
      color: #f1f5f9;
      margin-bottom: 8px;
    }
    .scenario-text p {
      font-size: 15px;
      color: var(--text-dim);
    }
    .scenario-text strong {
      color: var(--text);
      font-weight: 500;
    }

    /* The Fix */
    .fix-section {
      animation: fadeSlideIn 0.8s 0.5s ease both;
    }
    .fix-headline {
      font-family: var(--font-display);
      font-size: clamp(32px, 5vw, 48px);
      line-height: 1;
      margin-bottom: 16px;
      color: #f1f5f9;
    }
    .fix-desc {
      font-size: 16px;
      color: var(--text-dim);
      margin-bottom: 40px;
    }

    .demo-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 48px;
    }
    @media (max-width: 560px) {
      .demo-row { grid-template-columns: 1fr; }
    }
    .demo-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 20px;
    }
    .demo-card.danger { border-color: rgba(239, 68, 68, 0.15); }
    .demo-card.safe { border-color: rgba(139, 92, 246, 0.2); }
    .demo-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .demo-label.red { color: var(--red); }
    .demo-label.grn { color: var(--purple); }
    .demo-label::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
    }
    .demo-label.red::before { background: var(--red); }
    .demo-label.grn::before { background: var(--purple); }
    .demo-email {
      font-family: var(--font-mono);
      font-size: 14px;
      color: var(--text);
      word-break: break-all;
    }
    .demo-email .redact {
      color: var(--red);
      text-decoration: line-through;
      text-decoration-color: rgba(239, 68, 68, 0.4);
    }
    .demo-email .masked {
      color: var(--purple);
      background: rgba(139, 92, 246, 0.1);
      padding: 1px 6px;
      border-radius: 3px;
    }

    .cta-section {
      text-align: center;
      animation: fadeSlideIn 0.7s 0.7s ease both;
    }
    .cta-headline {
      font-family: var(--font-display);
      font-size: clamp(28px, 4.5vw, 40px);
      color: #f1f5f9;
      margin-bottom: 12px;
    }
    .cta-sub {
      font-size: 15px;
      color: var(--text-dim);
      margin-bottom: 32px;
    }

    .download-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: linear-gradient(135deg, var(--purple-dim), var(--purple));
      color: #fff;
      font-family: var(--font-body);
      font-size: 15px;
      font-weight: 700;
      padding: 16px 36px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.3s;
      box-shadow: 0 0 40px rgba(168, 85, 247, 0.2);
    }
    .download-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 60px rgba(168, 85, 247, 0.35);
    }
    .download-btn svg {
      width: 18px;
      height: 18px;
    }

    .cta-footnote {
      margin-top: 20px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-muted);
    }
    .cta-footnote a {
      color: var(--text-dim);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 64px 0;
    }

    .footer {
      text-align: center;
      padding-top: 0;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.8;
    }
    .footer-brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .footer-brand img {
      width: 28px;
      height: 28px;
      object-fit: contain;
    }
    .footer a {
      color: var(--text-dim);
      text-decoration: none;
    }
    .footer a:hover { color: var(--purple); }

    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 3px; }
  </style>
</head>
<body>

<div class="glow-top"></div>
<div class="glow-bottom"></div>

<div class="page">

  <div style="margin-bottom: 48px; animation: fadeSlideIn 0.5s ease both;">
    <img src="./assets/logo.png" alt="MailHush" style="width: 64px; height: 64px; border-radius: 14px;" />
  </div>

  <h1 class="hero-headline">
    Anthropic shipped Claude<br /><em>with your email exposed.</em><br />
    So we <span class="accent">cleaned up their mess.</span>
  </h1>

  <p class="hero-sub">
    Claude leaves your email sitting in the DOM like that's somehow acceptable.
    Stream your screen? Post a screenshot?
    <strong>nice, now random weirdos have your inbox because Anthropic couldn't ship one basic privacy toggle.</strong>
  </p>

  <div class="terminal">
    <div class="terminal-bar">
      <div class="terminal-dot"></div>
      <div class="terminal-dot"></div>
      <div class="terminal-dot"></div>
      <span>live-stream-disaster.sh</span>
    </div>
    <div class="terminal-body">
      <span class="comment"># you're live on stream, 2k viewers</span><br />
      <span class="prompt">streamer $</span> opens claude.ai<br />
      <span class="comment"># bottom-left corner, because apparently anthropic thought that was fine:</span><br />
      <span class="leak">johndoe.real@gmail.com</span><br />
      <span class="comment"># chat goes wild</span><br />
      <span class="dim">viewer42: "lmao we got his email"</span><br />
      <span class="dim">xXhackerXx: "already subscribed him to catfacts"</span><br /><br />
      <span class="comment"># what it looks like with MailHush:</span><br />
      <span class="prompt">streamer $</span> opens claude.ai<br />
      <span class="safe">nunya@business.com</span><br />
      <span class="dim">viewer42: "..."</span><br />
      <span class="prompt">streamer $</span> <span class="cursor-blink"></span>
    </div>
  </div>

  <div class="section-label">How it happens</div>
  <div class="scenarios">
    <div class="scenario">
      <div class="scenario-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      </div>
      <div class="scenario-text">
        <h3>The live stream moment</h3>
        <p>You open Claude on stream to flex your prompt skills. Anthropic leaves your email sitting in the corner the <strong>entire time</strong>. 2,000 people now have it because nobody at HQ found this embarrassing enough to fix.</p>
      </div>
    </div>
    <div class="scenario">
      <div class="scenario-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      </div>
      <div class="scenario-text">
        <h3>The screenshot post</h3>
        <p>You share a cool Claude conversation on Twitter. Forgot to crop the header. <strong>Your email is in 47 quote tweets</strong> before you notice, because Claude insists on wearing your identity like a name tag.</p>
      </div>
    </div>
    <div class="scenario">
      <div class="scenario-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="scenario-text">
        <h3>The team demo</h3>
        <p>Screen-sharing Claude in a meeting with clients. Your personal Gmail is right there. Very <strong>professional</strong>. incredible product instinct from the people who somehow missed this.</p>
      </div>
    </div>
  </div>

  <hr class="divider" />

  <div class="fix-section">
    <div class="section-label">The fix</div>
    <h2 class="fix-headline">
      MailHush replaces emails<br /><span class="accent">before anyone sees them.</span>
    </h2>
    <p class="fix-desc">
      A tiny browser extension that swaps email addresses in the DOM with whatever you want. No broken layouts. No page reloads. Just quiet, in-place replacement for a problem Anthropic should've solved themselves.
    </p>

    <div class="demo-row">
      <div class="demo-card danger">
        <div class="demo-label red">Without MailHush</div>
        <div class="demo-email">
          <span class="redact">johndoe.real@gmail.com</span>
        </div>
      </div>
      <div class="demo-card safe">
        <div class="demo-label grn">With MailHush</div>
        <div class="demo-email">
          <span class="masked">nunya@business.com</span>
        </div>
      </div>
    </div>
  </div>

  <hr class="divider" />

  <div class="cta-section">
    <h2 class="cta-headline">Stop letting Claude snitch your email.</h2>
    <p class="cta-sub">Works on Claude, ChatGPT, Gmail, and literally every other website that thinks your address should just be hanging out.</p>

    <a href="https://github.com/pc-style/mailhush/releases" class="download-btn" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download from GitHub
    </a>

    <p class="cta-footnote">
      Free &amp; open source &middot; Chrome &amp; Chromium browsers &middot;
      <a href="https://github.com/pc-style/mailhush" target="_blank" rel="noopener">source code</a>
    </p>
  </div>

  <hr class="divider" />

  <div class="footer">
    <a class="footer-brand" href="https://github.com/pc-style/mailhush">
      <img src="./assets/logo.png" alt="MailHush logo" />
      <span>MailHush</span>
    </a><br />
    privacy-first extension<br />
    built because Anthropic couldn't be bothered to add a hide button
  </div>

</div>
<script>
  import { inject } from '@vercel/analytics';

  inject();
</script>
</body>
</html>
