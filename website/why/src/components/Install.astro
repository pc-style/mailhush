---
// src/components/Install.astro
import GitHubIcon from '../assets/GitHub-dark.svg?raw';
import ZenIcon from '../assets/Zen Browser-dark.svg?raw';
import ChromeIcon from '../assets/Chrome.svg?raw';
---

<section class="install-section" id="install" aria-labelledby="install-title">
  <h2 id="install-title">Install</h2>

  <div class="install-options">
    <a
      href="https://addons.mozilla.org/en-US/firefox/addon/mailhush/"
      class="install-btn firefox"
      target="_blank"
      rel="noopener"
    >
      <div class="icon-wrapper" set:html={ZenIcon} />
      <div class="btn-text">
        <span class="btn-name">Firefox &amp; Zen</span>
        <span class="btn-status available">Mozilla Add-ons</span>
      </div>
    </a>

    <a
      href="https://github.com/pc-style/mailhush/releases/latest"
      class="install-btn github"
      target="_blank"
      rel="noopener"
    >
      <div class="icon-wrapper" set:html={GitHubIcon} />
      <div class="btn-text">
        <span class="btn-name">GitHub Releases</span>
        <span class="btn-status available">Latest build</span>
      </div>
    </a>

    <div class="install-btn chrome disabled" title="Coming soon to Chrome Web Store">
      <div class="icon-wrapper" set:html={ChromeIcon} />
      <div class="btn-text">
        <span class="btn-name">Chrome</span>
        <span class="btn-status coming-soon">Coming soon</span>
      </div>
    </div>
  </div>

  <p class="install-meta">Free &middot; open source &middot; runs locally.</p>
</section>

<style>
  .install-options {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }
  .install-btn {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.2s, border-color 0.2s, background 0.2s;
  }
  .install-btn:hover:not(.disabled) {
    transform: translateY(-2px);
    border-color: var(--purple);
    background: rgba(168, 85, 247, 0.05);
  }
  .install-btn.disabled {
    opacity: 0.6;
    cursor: not-allowed;
    filter: grayscale(0.8);
  }
  .icon-wrapper {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }
  .btn-text {
    display: flex;
    flex-direction: column;
  }
  .btn-name {
    font-size: 16px;
    font-weight: 600;
    color: #f1f5f9;
  }
  .btn-status {
    font-size: 13px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }
  .available {
    color: var(--purple);
  }
  .coming-soon {
    color: var(--text-muted);
  }
</style>
