---
// src/components/Scenarios.astro
---

<section aria-labelledby="how-it-happens">
  <h2 id="how-it-happens" class="section-label">How it happens</h2>
  <div class="scenarios">
    <article class="scenario">
      <div class="scenario-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      </div>
      <div class="scenario-text">
        <h3>The live stream</h3>
        <p>You open Claude on stream. Your email sits in the corner the entire time. <strong>2,000 viewers now have it.</strong></p>
      </div>
    </article>
    <article class="scenario">
      <div class="scenario-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      </div>
      <div class="scenario-text">
        <h3>The screenshot</h3>
        <p>You share a cool Claude conversation. Forgot to crop the header. <strong>Your email is in 47 quote tweets before you notice.</strong></p>
      </div>
    </article>
    <article class="scenario">
      <div class="scenario-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="scenario-text">
        <h3>The client demo</h3>
        <p>Screen-sharing Claude with clients. Your personal Gmail is right there. <strong>Very professional.</strong></p>
      </div>
    </article>
  </div>
</section>
